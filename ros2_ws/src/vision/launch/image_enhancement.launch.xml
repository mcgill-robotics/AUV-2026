<?xml version="1.0" encoding="UTF-8"?>
<launch>
    <arg name="front_cam_topic" default="/zed/zed_node/rgb/color/rect/image"/>
    <arg name="front_cam_depth_topic" default="/zed/zed_node/depth/depth_registered"/>
    <arg name="down_cam_topic" default="/sensors/down_cam/image_raw"/>
    <arg name="front_enhanced_topic" default="/vision/front_cam/image_enhanced"/>
    <arg name="down_enhanced_topic" default="/vision/down_cam/image_enhanced"/>
    <arg name="publish_rate" default="30"/>
    <arg name="sim" default="false"/>

    <let name="front_cam_topic" value="$(var front_cam_topic)/compressed" if="$(var sim)"/>
    <let name="down_cam_topic" value="$(var down_cam_topic)/compressed" if="$(var sim)"/>
    <let name="front_cam_depth_topic" value="$(var front_cam_depth_topic)/compressed" if="$(var sim)"/>
    <let name="front_enhanced_topic" value="$(var front_enhanced_topic)/compressed" if="$(var sim)"/>
    <let name="down_enhanced_topic" value="$(var down_enhanced_topic)/compressed" if="$(var sim)"/>
    <node pkg="vision" exec="front_image_enhancement" name="front_image_enhancement" output="screen">
        <param name="input_topic" value="$(var front_cam_topic)"/>
        <param name="output_topic" value="$(var front_enhanced_topic)"/>
        <param name="depth_topic" value="$(var front_cam_depth_topic)"/>
        <param name="publish_rate_hz" value="$(var publish_rate)"/>
        <param name="sim" value="$(var sim)"/>
        <param name="dsc_model_path" value="$(find-pkg-share vision)/models/dsc_pipeline.pt"/>
    </node>

    <node pkg="vision" exec="down_image_enhancement" name="down_image_enhancement" output="screen">
        <param name="input_topic" value="$(var down_cam_topic)"/>
        <param name="output_topic" value="$(var down_enhanced_topic)"/>
        <param name="publish_rate_hz" value="$(var publish_rate)"/>
        <param name="sim" value="$(var sim)"/>
    </node>
</launch>